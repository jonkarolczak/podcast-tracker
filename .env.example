# Copy to .env and fill in real values. NEVER commit .env.
# Same names are used as GitHub Actions secrets — keep them in sync.

# Anthropic — Claude API for filter (Haiku 4.5) and summarize (Sonnet 4.6)
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Exa — web search fallback for podcast discovery
# Get at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=xxxxxxxxxxxxxxxx

# PodcastIndex — primary podcast discovery
# Sign up at: https://api.podcastindex.org (free dev account)
PODCASTINDEX_API_KEY=xxxxxxxxxxxxxxxx
PODCASTINDEX_API_SECRET=xxxxxxxxxxxxxxxx

# Resend — daily digest email delivery
# Get at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email From/To
# Phase 1 (smoke test): use "Podcast Tracker <onboarding@resend.dev>" as From
# Phase 3 (production): switch to verified subdomain like "Podcast Tracker <digest@send.yourdomain.com>"
DIGEST_FROM_EMAIL=Podcast Tracker <onboarding@resend.dev>
DIGEST_TO_EMAIL=jonkarolczak@gmail.com
