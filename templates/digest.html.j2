<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <meta name="supported-color-schemes" content="light dark" />
  <title>Podcast Tracker — {{ run_date }}</title>
  <style>
    @media (max-width: 620px) {
      .container { width: 100% !important; }
      .pad { padding: 16px !important; }
    }
    @media (prefers-color-scheme: dark) {
      body, .bg { background-color: #1a1a1a !important; }
      .card { background-color: #242424 !important; }
      .text { color: #e8e8e8 !important; }
      .muted { color: #9a9a9a !important; }
      a { color: #8ab4f8 !important; }
    }
  </style>
</head>
<body class="bg" style="margin:0; padding:0; background-color:#f7f7f7; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="container" style="width:600px; max-width:600px;">
          <tr>
            <td class="pad text" style="padding:24px; color:#1a1a1a;">
              <h1 style="font-size:20px; margin:0 0 4px 0;">Podcast Tracker</h1>
              <p class="muted" style="color:#666; margin:0 0 24px 0; font-size:14px;">
                {{ run_date }} · {{ entries|length }} new
              </p>

              {% for entry in entries %}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="background:#fff; border-radius:8px; margin-bottom:20px;">
                  <tr>
                    <td style="padding:20px;">
                      <p class="muted" style="color:#888; margin:0 0 6px 0; font-size:11px; text-transform:uppercase; letter-spacing:0.05em;">
                        {{ entry.episode.candidate.match_type|replace("_", " ")|title }}
                        {%- if entry.episode.candidate.match_query %} · {{ entry.episode.candidate.match_query }}{% endif %}
                      </p>
                      <h2 style="font-size:18px; margin:0 0 6px 0; line-height:1.3;">{{ entry.episode.candidate.title }}</h2>
                      <p class="muted" style="color:#666; margin:0 0 14px 0; font-size:13px;">
                        {{ entry.episode.candidate.podcast }} · {{ entry.episode.candidate.published_at.strftime("%b %-d, %Y") }}
                        {%- if entry.episode.candidate.duration_minutes %} · {{ "%.0f"|format(entry.episode.candidate.duration_minutes) }} min{% endif %}
                      </p>

                      {% if entry.summary %}
                        <p style="font-style:italic; margin:0 0 14px 0; font-size:14px; line-height:1.5;">{{ entry.summary.headline }}</p>
                        <ul style="padding-left:20px; margin:0 0 14px 0;">
                          {% for bullet in entry.summary.bullets %}
                            <li style="margin-bottom:8px; line-height:1.5; font-size:14px;">
                              <span class="muted" style="color:#888; font-size:11px; font-weight:600; letter-spacing:0.04em;">{{ bullet.category }}</span><br />
                              {{ bullet.point }}
                            </li>
                          {% endfor %}
                        </ul>
                        {% if entry.summary.open_questions %}
                          <p class="muted" style="color:#666; margin:14px 0 6px 0; font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">Open questions</p>
                          <ul style="padding-left:20px; margin:0 0 14px 0;">
                            {% for q in entry.summary.open_questions %}
                              <li style="margin-bottom:4px; font-size:13px; color:#444;">{{ q }}</li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      {% elif entry.error %}
                        <p class="muted" style="color:#a04040; margin:0 0 14px 0; font-size:13px;">Processing error: {{ entry.error }}</p>
                      {% else %}
                        <p class="muted" style="color:#888; margin:0 0 14px 0; font-size:13px;">Transcript unavailable. Link only.</p>
                      {% endif %}

                      <p style="margin:0; font-size:13px;">
                        {% if entry.episode.candidate.episode_url %}
                          <a href="{{ entry.episode.candidate.episode_url }}" style="color:#1a73e8; text-decoration:none;">Listen</a>
                        {% endif %}
                      </p>
                    </td>
                  </tr>
                </table>
              {% else %}
                <p style="margin:0; font-size:14px;">No new matches in the last 24 hours.</p>
              {% endfor %}

              <p class="muted" style="color:#888; margin:32px 0 0 0; font-size:11px; text-align:center;">
                podcast-tracker · {{ run_date }}
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
