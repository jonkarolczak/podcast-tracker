<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <meta name="supported-color-schemes" content="light dark" />
  <title>{{ heading }}</title>
  <style>
    @media (max-width: 620px) {
      .container { width: 100% !important; }
      .pad { padding: 16px !important; }
    }
    @media (prefers-color-scheme: dark) {
      body, .bg { background-color: #1a1a1a !important; }
      .card { background-color: #242424 !important; }
      .text { color: #e8e8e8 !important; }
      .muted { color: #9a9a9a !important; }
      a { color: #8ab4f8 !important; }
    }
  </style>
</head>
<body class="bg" style="margin:0; padding:0; background-color:#f7f7f7; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" class="container" style="width:640px; max-width:640px;">
          <tr>
            <td class="pad text" style="padding:24px; color:#1a1a1a;">
              <h1 style="font-size:22px; margin:0 0 4px 0; line-height:1.3;">{{ heading }}</h1>
              <p class="muted" style="color:#666; margin:0 0 28px 0; font-size:14px;">{{ subheading }}</p>

              {% if failure_reason is defined and failure_reason %}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="background:#fff; border-radius:8px; margin-bottom:28px; border-left:4px solid #c44;">
                  <tr>
                    <td style="padding:24px;">
                      <p style="margin:0 0 12px 0; font-size:14px; line-height:1.6;">
                        All discovery surfaces failed during today's run. The pipeline did not process any episodes.
                      </p>
                      <p style="margin:0 0 12px 0; font-size:13px; line-height:1.6; color:#a04040;">
                        <strong>Reason:</strong> {{ failure_reason }}
                      </p>
                      <p style="margin:0; font-size:13px; line-height:1.6; color:#666;">
                        State was not committed. The next scheduled run will retry; if the issue persists, check the GitHub Actions logs.
                      </p>
                    </td>
                  </tr>
                </table>
              {% endif %}

              {% for ctx in contexts %}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="background:#fff; border-radius:8px; margin-bottom:28px;">
                  <tr>
                    <td style="padding:24px;">
                      <h2 style="font-size:18px; margin:0 0 16px 0; line-height:1.35;">
                        {{ ctx.n }}. {{ ctx.podcast }}{% if ctx.has_guest %}: {{ ctx.header_guest }}{% endif %}
                      </h2>

                      <p style="margin:0 0 18px 0; font-size:14px; line-height:1.65;">
                        <strong>Podcast:</strong> {{ ctx.podcast }}<br />
                        <strong>Episode:</strong> {{ ctx.episode_title }}<br />
                        <strong>Guests:</strong> {{ ctx.guests_display }}<br />
                        {% if ctx.role_and_company %}
                          <strong>Company / role:</strong> {{ ctx.role_and_company }}<br />
                        {% endif %}
                        <strong>Date:</strong> {{ ctx.date_display }}<br />
                        <strong>Link:</strong> {% if ctx.primary_url %}<a href="{{ ctx.primary_url }}" style="color:#1a73e8; text-decoration:none;">{{ ctx.primary_url }}</a>{% else %}—{% endif %}
                      </p>

                      {% if ctx.entry.summary %}
                        <h3 style="font-size:14px; margin:0 0 12px 0; text-transform:uppercase; letter-spacing:0.05em; color:#666;">
                          Summary
                        </h3>
                        <ul style="padding-left:20px; margin:0;">
                          {% for bullet in ctx.entry.summary.bullets %}
                            <li style="margin-bottom:10px; line-height:1.55; font-size:14px;">{{ bullet.point }}</li>
                          {% endfor %}
                        </ul>
                      {% elif ctx.entry.error %}
                        <p class="muted" style="color:#a04040; margin:0; font-size:13px;">Processing error: {{ ctx.entry.error }}</p>
                      {% else %}
                        <p class="muted" style="color:#888; margin:0; font-size:13px;">Transcript unavailable. Link only.</p>
                      {% endif %}
                    </td>
                  </tr>
                </table>
              {% else %}
                <p style="margin:0; font-size:14px;">No new matches in the last 24 hours.</p>
              {% endfor %}

              <p class="muted" style="color:#888; margin:32px 0 0 0; font-size:11px; text-align:center;">
                podcast-tracker
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
